{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "module": "commonjs",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "bundler",
    "composite": true
  }
}
