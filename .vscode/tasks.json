{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "admin:kill",
      "type": "shell",
      "command": "npx kill-port 5173",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "admin:dev",
      "type": "shell",
      "isBackground": true,
      "command": "pnpm",
      "args": [
        "--filter",
        "sbot-admin",
        "run",
        "debug",
        "--",
        "--port",
        "5173",
        "--strictPort"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": ""
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "(ready in|Local:).*"
        }
      }
    },
    {
      "label": "debug:cli",
      "type": "shell",
      "command": "pnpm run debug:cli",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "debug:sbot",
      "type": "shell",
      "command": "pnpm run debug:sbot",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "build:vscode-extension",
      "type": "shell",
      "command": "pnpm run build:vscode",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "launch:sbot",
      "dependsOn": ["admin:kill", "debug:sbot", "admin:dev"],
      "dependsOrder": "sequence"
    }
  ]
}
