{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "debug:cli",
      "type": "shell",
      "command": "pnpm run debug:cli",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "debug:sbot",
      "type": "shell",
      "command": "pnpm run debug:sbot",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    }
  ]
}
