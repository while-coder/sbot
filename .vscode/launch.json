{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch sbot",
      "program": "${workspaceFolder}/packages/sbot/debug/index.js",
      "preLaunchTask": "launch:sbot",
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/packages/sbot/debug/**/*.js",
        "${workspaceFolder}/packages/sbot.commons/dist/**/*.js",
        "${workspaceFolder}/packages/scorpio.di/dist/**/*.js",
        "${workspaceFolder}/packages/scorpio.ai/dist/**/*.js",
        "${workspaceFolder}/packages/channel.base/dist/**/*.js",
        "${workspaceFolder}/packages/channel.lark/dist/**/*.js",
        "${workspaceFolder}/packages/channel.slack/dist/**/*.js",
        "${workspaceFolder}/packages/channel.wecom/dist/**/*.js"
      ],
      "cwd": "${workspaceFolder}/packages/sbot",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch cli",
      "program": "${workspaceFolder}/packages/cli/debug/main.js",
      "preLaunchTask": "debug:cli",
      "console": "externalTerminal",
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/packages/cli/debug/**/*.js",
        "${workspaceFolder}/packages/sbot.commons/dist/**/*.js",
        "${workspaceFolder}/packages/sbot.commons/esm/**/*.js"
      ],
      "cwd": "${workspaceFolder}/packages/cli",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
