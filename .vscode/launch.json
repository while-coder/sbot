{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch sbot",
      "program": "${workspaceFolder}/packages/sbot/debug/index.js",
      "preLaunchTask": "debug:sbot",
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/packages/sbot/debug/**/*.js",
        "${workspaceFolder}/packages/scorpio.ai/dist/**/*.js",
        "${workspaceFolder}/packages/channel.lark/dist/**/*.js"
      ],
      "cwd": "${workspaceFolder}/packages/sbot",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch cli",
      "runtimeExecutable": "${workspaceFolder}/packages/cli/node_modules/.bin/tsx",
      "args": ["${workspaceFolder}/packages/cli/src/main.tsx"],
      "cwd": "${workspaceFolder}/packages/cli",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
