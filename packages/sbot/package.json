{
  "name": "@qingfeng346/sbot",
  "version": "0.1.2",
  "description": "Self-hosted AI agent server. Open-source alternative to OpenAI, Claude, and Gemini interfaces. Run LLM agents locally with MCP tool support, memory, multi-channel integrations (Lark/Feishu), and a built-in web UI.",
  "releasenoteEn": "### test",
  "releasenoteZh": "### 测试",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/while-coder/sbot.git"
  },
  "homepage": "https://github.com/while-coder/sbot#readme",
  "bugs": {
    "url": "https://github.com/while-coder/sbot/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/dist/index.js",
  "bin": {
    "sbot": "./dist/dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true,
    "access": "public"
  },
  "scripts": {
    "debug": "rimraf debug && tsc -p tsconfig.debug.json && node scripts/postbuild.js debug",
    "build": "rimraf dist && tsc && node scripts/postbuild.js",
    "build:bundle": "rimraf dist && node scripts/bundle.js && node scripts/postbuild.js",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@langchain/core": "catalog:",
    "adm-zip": "^0.5.17",
    "axios": "catalog:",
    "channel.base": "workspace:*",
    "channel.lark": "workspace:*",
    "channel.slack": "workspace:*",
    "channel.onebot": "workspace:*",
    "channel.wechat": "workspace:*",
    "channel.wecom": "workspace:*",
    "commander": "catalog:",
    "cron": "^4.4.0",
    "diff": "^9.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "log4js": "^6.9.1",
    "reflect-metadata": "catalog:",
    "sbot.commons": "workspace:*",
    "scorpio.ai": "workspace:*",
    "scorpio.di": "workspace:*",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "turndown": "^7.2.4",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/diff": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/turndown": "^5.0.6",
    "@types/ws": "catalog:",
    "esbuild": "^0.28.0",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
