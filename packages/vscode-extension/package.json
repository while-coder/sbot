{
  "name": "sbot-vscode",
  "displayName": "sbot",
  "description": "Chat with sbot AI server inside VS Code",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sbot",
          "title": "sbot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sbot": [
        {
          "type": "webview",
          "id": "sbot.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "sbot.openChat",
        "title": "sbot: Open Chat"
      },
      {
        "command": "sbot.selectServer",
        "title": "sbot: Select Server"
      }
    ],
    "keybindings": [
      {
        "command": "sbot.openChat",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      }
    ]
  },
  "scripts": {
    "copy-assets": "cp ../shared-assets/logo.svg media/icon.svg",
    "build": "pnpm run copy-assets && pnpm run build:ext && pnpm run build:webview",
    "build:ext": "node scripts/build-ext.mjs",
    "build:webview": "vite build",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "watch:webview": "vite build --watch",
    "dev": "concurrently \"pnpm run watch:ext\" \"pnpm run watch:webview\""
  },
  "dependencies": {
    "@sbot/chat-ui": "workspace:*",
    "axios": "catalog:",
    "shared-assets": "workspace:*",
    "sbot.commons": "workspace:*",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "^1.85.0",
    "@types/ws": "catalog:",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.0",
    "typescript": "catalog:",
    "vite": "^8.0.9",
    "vue": "^3.5.33"
  }
}
