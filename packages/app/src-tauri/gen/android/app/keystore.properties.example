# Copy to keystore.properties (in this same directory) and fill in.
# keystore.properties is gitignored; this .example file is committed for reference.
# Alternatively, set ANDROID_KEYSTORE_PATH / ANDROID_KEYSTORE_PASSWORD /
# ANDROID_KEY_ALIAS / ANDROID_KEY_PASSWORD as environment variables.
storeFile=../../../../secrets/release.jks
keyAlias=
storePassword=
keyPassword=
