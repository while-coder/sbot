{
  "name": "@sbot/pwa",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-assets": "cp ../shared-assets/logo.svg public/ && cp ../shared-assets/pwa-192x192.png public/ && cp ../shared-assets/pwa-512x512.png public/",
    "dev": "pnpm run copy-assets && vite",
    "build": "pnpm run copy-assets && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@sbot/chat-ui": "workspace:*",
    "shared-assets": "workspace:*",
    "sbot.commons": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "catalog:",
    "vite": "^8.0.9",
    "vite-plugin-pwa": "^1.0.0",
    "vue": "^3.5.33"
  }
}
