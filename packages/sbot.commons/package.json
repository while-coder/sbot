{
  "name": "sbot.commons",
  "version": "0.0.1",
  "description": "Shared TypeScript interfaces and types for sbot packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist esm && tsc -b --force && tsc -p tsconfig.esm.json"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
