# Android signing — copy to ../secrets/keystore.properties and fill in.
# `storeFile` is resolved relative to this properties file, so just the filename is enough.
# Alternatively, set ANDROID_KEYSTORE_PATH / ANDROID_KEYSTORE_PASSWORD /
# ANDROID_KEY_ALIAS / ANDROID_KEY_PASSWORD as environment variables (used in CI).
storeFile=release.jks
keyAlias=
storePassword=
keyPassword=
