{
  "name": "sbot-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r run build",
    "debug:sbot": "pnpm --filter @qingfeng346/sbot run debug",
    "debug:cli": "pnpm --filter sbot-cli run debug",
    "debug:website": "pnpm --filter sbot-website run debug",
    "build:sbot": "pnpm --filter @qingfeng346/sbot run build",
    "link:sbot": "pnpm --filter @qingfeng346/sbot run build && npm link packages/sbot/dist",
    "unlink:sbot": "npm unlink -g @qingfeng346/sbot",
    "publish:sbot": "pnpm --filter @qingfeng346/sbot publish --no-git-checks --access public",
    "publish:cli": "pnpm --filter sbot-cli publish --no-git-checks"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sqlite3"
    ]
  }
}
