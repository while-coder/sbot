{
  "name": "sbot-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r run build",
    "debug:sbot": "pnpm --filter sbot run debug",
    "debug:cli": "pnpm --filter sbot-cli run debug",
    "debug:website": "pnpm --filter sbot-website run debug",
    "publish:sbot": "pnpm --filter sbot publish",
    "publish:cli": "pnpm --filter sbot-cli publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sqlite3"
    ]
  }
}
