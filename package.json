{
  "name": "sbot-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r run build && pnpm --filter sbot-website run build",
    "debug:sbot": "pnpm --filter @while/sbot run debug",
    "debug:cli": "pnpm --filter sbot-cli run debug",
    "debug:website": "pnpm --filter sbot-website run debug",
    "publish:sbot": "pnpm --filter @while/sbot publish --no-git-checks",
    "publish:cli": "pnpm --filter sbot-cli publish --no-git-checks"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sqlite3"
    ]
  }
}
